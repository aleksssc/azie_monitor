{
  "name": "azie-monitor",
  "version": "1.0.1",
  "description": "Desktop infrastructure and network monitoring platform.",
  "main": "main.js",
  "author": "Alexandre Cardinha",

  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },

  "build": {
    "appId": "com.azie.monitor",
    "productName": "Azie Monitor",

    "directories": {
      "output": "dist"
    },

    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.cache/**",
      "!*.md",
      "!README.md",
      "!LICENSE"
    ],

    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/img/logo.ico"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },

  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },

  "dependencies": {
    "whois": "^2.16.2"
  }
}